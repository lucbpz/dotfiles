#!/usr/bin/env bash
set -euo pipefail

BRANCH=$(osascript -e 'text returned of (display dialog "Branch name:" default answer "" with title "New Worktree")') || exit 0
[ -z "$BRANCH" ] && exit 0

PROMPT=$(osascript -e 'text returned of (display dialog "Claude prompt (optional):" default answer "" with title "New Worktree")') || exit 0

if [ -n "$PROMPT" ]; then
    wtree "$BRANCH" "$PROMPT"
else
    wtree "$BRANCH"
fi
